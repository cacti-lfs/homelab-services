services:
  front:
    image: tombursch/kitchenowl-web:latest
    restart: unless-stopped
    ports:
      - "{{ kitchenowl_front_port | default(8244) }}:80"
    depends_on:
      - back

  back:
    image: tombursch/kitchenowl:latest
    restart: unless-stopped
    environment:
      - JWT_SECRET_KEY={{ kitchenowl_jwt_secret }}
    volumes:
      - /srv/appdata/kitchenowl/data:/data

volumes:
  kitchenowl_data:
